# Frontend public domain stays in EasyPanel: condados.devnx.com.br
# This points the frontend container to the Airbyte API exposed on the Docker host.
AILIV_API_URL=http://172.17.0.1:8002
NGINX_RESOLVER=127.0.0.11

# Airbyte abctl install.
AIRBYTE_PORT=8002
AIRBYTE_EMAIL=admin@devnx.com.br
AIRBYTE_PASSWORD=change-me-now

# Leave empty unless you also expose the native Airbyte UI/API directly.
AIRBYTE_HOST=
AIRBYTE_INSECURE_COOKIES=false

# Set true only on small servers. Airbyte disables Connector Builder in low resource mode.
AIRBYTE_LOW_RESOURCE_MODE=false

# Optional. Leave empty to install the latest Airbyte Helm chart.
AIRBYTE_CHART_VERSION=
